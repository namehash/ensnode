    },
    {
      "id": "3i8yEJgh6ZqCMgLihxCTh",
      "type": "text",
      "x": 2430.2125784283203,
      "y": -1011.6971262406414,
      "width": 381.023681640625,
      "height": 80,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 0,
      "groupIds": [],
      "frameId": "eiRo4qNzmGdR3IkmHExUd",
      "index": "b3y",
      "roundness": null,
      "seed": 760629793,
      "version": 7418,
      "versionNonce": 189637985,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777539111921,
      "link": null,
      "locked": false,
      "text": "It's an idempotent task, managed by Drizzle Kit tool,\nwhere all pending migrations, after being executed\nexactly once, are marked as executed and will not be\nconsidered pending anymore.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "42ADfMBmAaRVnK6pb4Ytp",
      "originalText": "It's an idempotent task, managed by Drizzle Kit tool, where all pending migrations, after being executed exactly once, are marked as executed and will not be considered pending anymore.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "iMBBkDRTwPauK4hy3CNNQ",
      "type": "rectangle",
      "x": 2381.4000069390713,
      "y": -1086.0664873789638,
      "width": 509.4115690865348,
