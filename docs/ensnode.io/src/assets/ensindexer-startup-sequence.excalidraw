      "seed": 1958524673,
      "version": 4384,
      "versionNonce": 1553159073,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777539111911,
      "link": null,
      "locked": false,
      "text": "Create the Ponder Build ID as a checksum, based on the following values:\n- The internal Ponder `BUILD_ID_VERSION` const\n- The Ponder Config Checksum\n- The Ponder Schema Checksum\n- The Ponder Event Handlers Checksum",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "ULKJKn4UH53hY3NBitPVN",
      "originalText": "Create the Ponder Build ID as a checksum, based on the following values:\n- The internal Ponder `BUILD_ID_VERSION` const\n- The Ponder Config Checksum\n- The Ponder Schema Checksum\n- The Ponder Event Handlers Checksum",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Pgpd0ILy1OlnuX1pQ4B6P",
      "type": "rectangle",
      "x": -685.3450742047025,
      "y": -1846.3537367653562,
      "width": 356.6255459816191,
      "height": 185.7383824286835,
      "angle": 0,
      "strokeColor": "#fff9db",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
