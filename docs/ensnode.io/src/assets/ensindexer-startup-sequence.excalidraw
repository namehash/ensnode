    },
    {
      "id": "2N8HOGjTjaj6oeLF0VPS_",
      "type": "text",
      "x": -1730.2079496430977,
      "y": -1155.3037084387006,
      "width": 205.37583923339844,
      "height": 480,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": "eiRo4qNzmGdR3IkmHExUd",
      "index": "b3I",
      "roundness": null,
      "seed": 1579721569,
      "version": 8007,
      "versionNonce": 1453542081,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777539111920,
      "link": null,
      "locked": false,
      "text": "All routes are available right\naway, however, each has its\nown internal logic to decide\nHTTP response code. For\nexample:\n\n/metrics is always 200 OK,\nbut some metrics will be\nincluded only after Ponder\nexecutes the setup handlers\n\n/health is always 200 OK\n\n/ready is 503 when the\n`is_ready` field in the\nPonder Metadata record is\nset to `0`; otherwise it's 200\nOK\n\n/status is always 200 OK,\nbut per chain indexing\nstatus will be included only\nafter Ponder executes the\nsetup handlers",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "b3NpsmoiN1Qyo5fmFVKBE",
      "originalText": "All routes are available right away, however, each has its own internal logic to decide HTTP response code. For example:\n\n/metrics is always 200 OK, but some metrics will be included only after Ponder executes the setup handlers\n\n/health is always 200 OK\n\n/ready is 503 when the `is_ready` field in the Ponder Metadata record is set to `0`; otherwise it's 200 OK\n\n/status is always 200 OK, but per chain indexing status will be included only after Ponder executes the setup handlers",
      "autoResize": true,
      "lineHeight": 1.25
    },
