    },
    {
      "id": "w3iuK18KcA_acEPR2DTj5",
      "type": "text",
      "x": 2912.183958196386,
      "y": -1035.940326897468,
      "width": 432.91162109375,
      "height": 200,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 0,
      "groupIds": [],
      "frameId": "eiRo4qNzmGdR3IkmHExUd",
      "index": "b4H",
      "roundness": null,
      "seed": 1146974145,
      "version": 6006,
      "versionNonce": 2117299425,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777539111922,
      "link": null,
      "locked": false,
      "text": "The setup handlers preconditions will be executed just once\nfor the given ENSIndexer instace. However, if there are\nmultiple ENSIndexer instances connected to the same\nENSDb instance, then the setup handlers preconditions will\nbe executed as many times as many ENSIndexer instances\nare connected to the ENSDb instance.\n\nTherefore, all tasks executed for the setup handler\npreconditions step MUST BE idempotent in order to avoid\nunexpected side effects.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": "g384shSITxn3mfzVjdGdq",
      "originalText": "The setup handlers preconditions will be executed just once for the given ENSIndexer instace. However, if there are multiple ENSIndexer instances connected to the same ENSDb instance, then the setup handlers preconditions will be executed as many times as many ENSIndexer instances are connected to the ENSDb instance.\n\nTherefore, all tasks executed for the setup handler preconditions step MUST BE idempotent in order to avoid unexpected side effects.",
      "autoResize": true,
      "lineHeight": 1.25
    },
