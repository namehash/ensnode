    },
    {
      "id": "A9pVpfTTz2URxIOG1PZEI",
      "type": "text",
      "x": -677.9201796318617,
      "y": -1833.4845455510144,
      "width": 341.7757568359375,
      "height": 160,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": "eiRo4qNzmGdR3IkmHExUd",
      "index": "b2r",
      "roundness": null,
      "seed": 1940499137,
      "version": 6967,
      "versionNonce": 1048802113,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777539111919,
      "link": null,
      "locked": false,
      "text": "Note: For ENSIndexer, there's just one file that\ncan be considered a Ponder Event Handler file:\napps/ensindexer/ponder/src/register-handlers.ts\n\nThis file imports all other files which call\n`ponder.on` function internally. Any changes\nmade in these other files won't cause the\nPonder Event Handlers Checksum to change.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Pgpd0ILy1OlnuX1pQ4B6P",
      "originalText": "Note: For ENSIndexer, there's just one file that can be considered a Ponder Event Handler file:\napps/ensindexer/ponder/src/register-handlers.ts\n\nThis file imports all other files which call `ponder.on` function internally. Any changes made in these other files won't cause the Ponder Event Handlers Checksum to change.",
      "autoResize": true,
      "lineHeight": 1.25
    },
