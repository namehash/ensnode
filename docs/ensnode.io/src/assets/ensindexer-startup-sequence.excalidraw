      "boundElements": [],
      "updated": 1777539111919,
      "link": null,
      "locked": false,
      "text": "Note: the Ponder Schema file\nfor ENSIndexer is a simple\nstatic file which re-exports\nthe ENSIndexer Schema\ndefintion from the ENSDb\nSDK package. Therefore, the\nPonder Schema Checksum\nwon't be changed in case\nENSIndexer Schema defintion\nchanges, as no updates will\nbe done to the literal contents\nof the Ponder Schema file.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "39FBIJMZPTl6BlVrUTg_L",
      "originalText": "Note: the Ponder Schema file for ENSIndexer is a simple static file which re-exports the ENSIndexer Schema defintion from the ENSDb SDK package. Therefore, the Ponder Schema Checksum won't be changed in case ENSIndexer Schema defintion changes, as no updates will be done to the literal contents of the Ponder Schema file.",
      "autoResize": true,
      "lineHeight": 1.25
    },
