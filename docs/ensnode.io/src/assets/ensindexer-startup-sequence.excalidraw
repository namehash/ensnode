      "isDeleted": false,
      "boundElements": [],
      "updated": 1777539111921,
      "link": null,
      "locked": false,
      "text": "Execute all migrations (i.e. ENSNode Schema migratiosn) from\nthe `packages/ensdb-sdk/migrations` dir\nthat are pending for the ENSDb instance. ",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "iMBBkDRTwPauK4hy3CNNQ",
      "originalText": "Execute all migrations (i.e. ENSNode Schema migratiosn) from\nthe `packages/ensdb-sdk/migrations` dir\nthat are pending for the ENSDb instance. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
