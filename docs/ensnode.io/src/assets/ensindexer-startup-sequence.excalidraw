      "isDeleted": false,
      "boundElements": [],
      "updated": 1777539111911,
      "link": null,
      "locked": false,
      "text": "\n    Executing setup handlers preconditions\n    (100% driven by ENSIndexer, executed just once for the given \n    ENSIndexer instance, won't be executed after ENSIndexer restarted)",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "Lutlxl2GGnAl1jC1PfJJR",
      "originalText": "\n    Executing setup handlers preconditions\n    (100% driven by ENSIndexer, executed just once for the given \n    ENSIndexer instance, won't be executed after ENSIndexer restarted)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "42ADfMBmAaRVnK6pb4Ytp",
      "type": "rectangle",
      "x": 2414.3590766666493,
      "y": -1016.6971262406414,
