    {
      "id": "K8kRMw3nu7nCWcKc5laZs",
      "type": "text",
      "x": -680.885234970232,
      "y": -2361.796783403899,
      "width": 530.9595947265625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
