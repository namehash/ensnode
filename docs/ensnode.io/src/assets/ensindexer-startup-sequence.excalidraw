      "isDeleted": false,
      "boundElements": [],
      "updated": 1777539111920,
      "link": null,
      "locked": false,
      "text": "It's possible that there will be\nsome new migrations added\nfor the Ponder Schema with\nthe new Ponder releases.\nThese new migrations will be\nconsidered pending until they\nare executed once.",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "zEFmM5tNObg1yXZO1KHwO",
      "originalText": "It's possible that there will be some new migrations added for the Ponder Schema with the new Ponder releases. These new migrations will be considered pending until they are executed once.",
      "autoResize": true,
      "lineHeight": 1.25
    },
