---
import { Icon } from "@astrojs/starlight/components";
import type { ENSNamespaceId } from "@ensnode/ensnode-sdk";

import { buildOmnigraphCurlExample, getHostedEnsNodeInstanceDocUrl } from "@lib/playground/utils";
import {
  SETUP_PACKAGE_MANAGERS,
  SETUP_TAB_LABELS,
  type SetupPackageManager,
} from "@lib/omnigraph-examples/build-integration-snippets";
import OmnigraphExampleActionBar from "@components/molecules/omnigraph-example/OmnigraphExampleActionBar.astro";
import OmnigraphExampleCodeSection from "@components/molecules/omnigraph-example/OmnigraphExampleCodeSection.astro";
import OmnigraphExampleSdkPanel from "@components/molecules/omnigraph-example/OmnigraphExampleSdkPanel.astro";
import OmnigraphExampleTabbedSection, {
  type OmnigraphExampleTab,
  type OmnigraphExampleTabPanel,
} from "@components/molecules/omnigraph-example/OmnigraphExampleTabbedSection.astro";

export interface OmnigraphAPIExamplePanelsProps {
  /** Unique id prefix for aria / tab wiring (e.g. example id). */
  panelId: string;
  query: string;
  variablesJson: string;
  variablesObject: Record<string, unknown>;
  responseJson: string | null;
  /** ENSNode base URL (same as enssdk `createEnsNodeClient({ url })`). */
  connectionBaseUrl: string;
  /** Starlight heading anchor on the hosted instances page (e.g. `ensnode-v2-sepolia`). */
  hostedInstanceAnchor: string;
  /** ENS namespace label for the hosted instance (e.g. `sepolia-v2`). */
  hostedInstanceNamespace: ENSNamespaceId;
  adminUrl: string;
  hideCurl?: boolean;
  enssdkSnippet: string;
  enskitSnippet: string;
  enssdkSetupSnippets: Record<SetupPackageManager, string>;
  enskitSetupSnippets: Record<SetupPackageManager, string>;
}

const {
  panelId,
  query,
  variablesJson,
  variablesObject,
  responseJson,
  connectionBaseUrl,
  hostedInstanceAnchor,
  hostedInstanceNamespace,
  adminUrl,
  hideCurl = false,
  enssdkSnippet,
  enskitSnippet,
  enssdkSetupSnippets,
  enskitSetupSnippets,
} = Astro.props;

const hostedInstanceDocUrl = getHostedEnsNodeInstanceDocUrl(hostedInstanceAnchor);
const uid = panelId.replace(/[^a-zA-Z0-9_-]/g, "-");

const exampleTabClass =
  "example-tab relative pb-2.5 pr-4 pt-2 text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--sl-color-text-accent)]";
const integrationTabClass = `${exampleTabClass} integration-tab`;
const setupPmTabClass = `${exampleTabClass} setup-pm-tab`;
const formatTabClass = exampleTabClass;

const integrationTabs = [
  { id: "graphql", label: "Omnigraph", icon: "seti:graphql" },
  { id: "enssdk", label: "enssdk", icon: "seti:typescript" },
  { id: "enskit", label: "enskit", icon: "seti:react" },
] as const;

const tabIds = {
  vars: `${uid}-tab-vars`,
  resp: `${uid}-tab-resp`,
  curl: `${uid}-tab-curl`,
} as const;

const curlExample = !hideCurl
  ? buildOmnigraphCurlExample({ connectionBaseUrl, query, variables: variablesObject })
  : "";

const graphqlTabs: OmnigraphExampleTab[] = [
  { id: tabIds.vars, label: "Variables", icon: "seti:json" },
  ...(responseJson ? [{ id: tabIds.resp, label: "Response", icon: "seti:json" }] : []),
  ...(!hideCurl && curlExample ? [{ id: tabIds.curl, label: "Curl", icon: "window" }] : []),
];

const graphqlPanels: OmnigraphExampleTabPanel[] = [
  {
    id: tabIds.vars,
    code: variablesJson,
    lang: "json",
    maxHeight: "min(38vh,19rem)",
    visible: true,
  },
  ...(responseJson
    ? [
        {
          id: tabIds.resp,
          code: responseJson,
          lang: "json",
          maxHeight: "min(50vh,28rem)",
          visible: false,
        },
      ]
    : []),
  ...(!hideCurl && curlExample
    ? [
        {
          id: tabIds.curl,
          code: curlExample,
          lang: "bash",
          maxHeight: "min(50vh,28rem)",
          visible: false,
        },
      ]
    : []),
];

function buildSdkTabs(prefix: "enssdk" | "enskit"): OmnigraphExampleTab[] {
  const tabs = SETUP_PACKAGE_MANAGERS.map((pm) => ({
    id: `${uid}-tab-setup-${prefix}-${pm}`,
    label: SETUP_TAB_LABELS[pm],
    icon: pm,
  }));
  if (responseJson) {
    tabs.push({
      id: `${uid}-tab-output-${prefix}`,
      label: "Output",
      icon: "seti:json",
    });
  }
  return tabs;
}

function buildSdkPanels(
  prefix: "enssdk" | "enskit",
  snippets: Record<SetupPackageManager, string>,
): OmnigraphExampleTabPanel[] {
  const panels: OmnigraphExampleTabPanel[] = SETUP_PACKAGE_MANAGERS.map((pm, i) => ({
    id: `${uid}-tab-setup-${prefix}-${pm}`,
    code: snippets[pm],
    lang: "bash",
    maxHeight: "min(38vh,19rem)",
    visible: i === 0,
  }));

  if (responseJson) {
    panels.push({
      id: `${uid}-tab-output-${prefix}`,
      code: responseJson,
      lang: "json",
      maxHeight: "min(50vh,28rem)",
      visible: false,
    });
  }

  return panels;
}

const enssdkSdkTabs = buildSdkTabs("enssdk");
const enskitSdkTabs = buildSdkTabs("enskit");
const enssdkSdkPanels = buildSdkPanels("enssdk", enssdkSetupSnippets);
const enskitSdkPanels = buildSdkPanels("enskit", enskitSetupSnippets);

const footerClass =
  "px-4 pb-4 pt-0 text-[0.7rem] leading-relaxed text-[var(--sl-color-gray-3)] md:px-5";
---

<div
  class="not-content not-prose omnigraph-example overflow-hidden my-8 rounded-xl border border-black/[0.06] bg-[var(--sl-color-gray-6)] shadow-sm dark:border-white/[0.08] dark:bg-[var(--sl-color-gray-7)]"
  data-omnigraph-example={uid}>
  <div
    class="flex items-end gap-0 border-b border-black/[0.06] dark:border-white/[0.08] px-4 md:px-5 pt-3"
    role="tablist"
    aria-label="Integration method"
    data-integration-tabs={uid}>
    {
      integrationTabs.map((tab, i) => (
        <button
          type="button"
          role="tab"
          id={`${uid}-int-tab-${tab.id}`}
          aria-selected={i === 0 ? "true" : "false"}
          aria-controls={`${uid}-int-${tab.id}`}
          data-integration-tab={tab.id}
          class={integrationTabClass}>
          <Icon name={tab.icon} class="tab-icon" size="1.125em" />
          <span class="tab-label">{tab.label}</span>
        </button>
      ))
    }
  </div>

  <div
    id={`${uid}-int-graphql`}
    data-integration-panel="graphql"
    role="tabpanel"
    aria-labelledby={`${uid}-int-tab-graphql`}>
    <OmnigraphExampleActionBar
      variant="ensadmin"
      adminUrl={adminUrl}
      hostedInstanceDocUrl={hostedInstanceDocUrl}
      hostedInstanceNamespace={hostedInstanceNamespace}
    />

    <OmnigraphExampleCodeSection
      badge="GraphQL"
      headingId={`${uid}-query-heading`}
      code={query}
      lang="graphql"
    />

    <OmnigraphExampleTabbedSection
      tabsRootId={uid}
      tablistAriaLabel="Example formats"
      srHeading={{ id: `${uid}-secondary-heading`, label: "Payload and transport examples" }}
      tabs={graphqlTabs}
      panels={graphqlPanels}
      tabButtonClass={formatTabClass}
      tabIconClass="tab-icon"
    />

    <p class={footerClass}>
      Response is an illustrative snapshot; live data depends on your ENSNode instance. The curl tab
      shows a POST to
      <code class="rounded bg-black/[0.06] px-1 py-0.5 font-mono text-[0.8em] dark:bg-white/[0.08]"
        >{connectionBaseUrl}/api/omnigraph</code
      >
    </p>
  </div>

  <OmnigraphExampleSdkPanel
    uid={uid}
    integrationId="enssdk"
    codeBadge="TypeScript"
    snippet={enssdkSnippet}
    snippetLang="typescript"
    setupTabsRoot={`${uid}-enssdk`}
    setupTabs={enssdkSdkTabs}
    setupPanels={enssdkSdkPanels}
    hasOutput={Boolean(responseJson)}
    docsHref="/docs/integrate/integration-options/enssdk"
    docsLabel="enssdk docs"
    footerSuffix="for gql.tada plugin and tsconfig setup."
    hostedInstanceDocUrl={hostedInstanceDocUrl}
    hostedInstanceNamespace={hostedInstanceNamespace}
    tabButtonClass={setupPmTabClass}
    tabIconClass="tab-icon"
  />

  <OmnigraphExampleSdkPanel
    uid={uid}
    integrationId="enskit"
    codeBadge="TSX (React)"
    snippet={enskitSnippet}
    snippetLang="tsx"
    setupTabsRoot={`${uid}-enskit`}
    setupTabs={enskitSdkTabs}
    setupPanels={enskitSdkPanels}
    hasOutput={Boolean(responseJson)}
    docsHref="/docs/integrate/integration-options/enskit"
    docsLabel="enskit docs"
    footerSuffix="for gql.tada plugin and provider setup."
    hostedInstanceDocUrl={hostedInstanceDocUrl}
    hostedInstanceNamespace={hostedInstanceNamespace}
    tabButtonClass={setupPmTabClass}
    tabIconClass="tab-icon"
  />
</div>

<script define:vars={{ uid }}>
  const root = document.querySelector(`[data-omnigraph-example="${uid}"]`);
  if (!root) return;

  const integrationTabsEl = root.querySelector(`[data-integration-tabs="${uid}"]`);
  const integrationPanels = [...root.querySelectorAll("[data-integration-panel]")];
  const integrationButtons = integrationTabsEl
    ? [...integrationTabsEl.querySelectorAll("[data-integration-tab]")]
    : [];

  function activateIntegration(name) {
    for (const btn of integrationButtons) {
      btn.setAttribute("aria-selected", btn.dataset.integrationTab === name ? "true" : "false");
    }
    for (const panel of integrationPanels) {
      const on = panel.dataset.integrationPanel === name;
      panel.classList.toggle("hidden", !on);
      panel.toggleAttribute("hidden", !on);
    }
  }

  if (integrationTabsEl) {
    integrationTabsEl.addEventListener("click", (e) => {
      const btn = e.target instanceof Element ? e.target.closest("[data-integration-tab]") : null;
      if (btn && integrationTabsEl.contains(btn)) {
        activateIntegration(btn.dataset.integrationTab);
      }
    });
  }

  for (const tabsRoot of root.querySelectorAll("[data-tabs-root]")) {
    if (tabsRoot.dataset.bound) continue;
    tabsRoot.dataset.bound = "true";

    const buttons = [...tabsRoot.querySelectorAll("[data-tab-target]")];
    const panels = [...tabsRoot.querySelectorAll("[data-tab-panel]")];

    function activate(targetId) {
      for (const btn of buttons) {
        btn.setAttribute(
          "aria-selected",
          btn.getAttribute("data-tab-target") === targetId ? "true" : "false",
        );
      }
      for (const panel of panels) {
        const on = panel.getAttribute("data-tab-panel") === targetId;
        panel.classList.toggle("hidden", !on);
        panel.toggleAttribute("hidden", !on);
      }
    }

    tabsRoot.addEventListener("click", (e) => {
      const btn = e.target instanceof Element ? e.target.closest("[data-tab-target]") : null;
      if (btn && tabsRoot.contains(btn)) {
        activate(btn.getAttribute("data-tab-target"));
      }
    });
  }
</script>

<style>
  .omnigraph-example :global(.expressive-code) {
    --ec-brdRad: 0.5rem;
  }

  .omnigraph-example :global(.expressive-code button) {
    cursor: pointer;
  }

  .omnigraph-example :global(.example-tab) {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    line-height: 1;
    color: var(--sl-color-gray-3);
    background: transparent;
    border: none;
    cursor: pointer;
  }

  .omnigraph-example :global(.tab-label) {
    line-height: 1;
  }

  .omnigraph-example :global(.tab-icon) {
    opacity: 0.9;
    flex-shrink: 0;
    display: block;
    width: 1.125em;
    height: 1.125em;
  }

  .omnigraph-example :global(.example-tab:hover) {
    color: var(--sl-color-gray-1);
  }

  /*
   * The ::after pseudo-element draws a 2px accent underline at bottom: -1px,
   * overlapping (and visually cancelling) the tablist container's border-b.
   * z-index: 1 ensures it renders above that border.
   */
  .omnigraph-example :global(.example-tab[aria-selected="true"]) {
    color: var(--sl-color-text-accent);
    z-index: 1;
  }

  .omnigraph-example :global(.example-tab[aria-selected="true"]::after) {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    inset-inline-end: 1rem; /* matches pr-4 so line ends at text edge */
    bottom: -1px;
    height: 2px;
    background: var(--sl-color-text-accent);
    border-radius: 2px 2px 0 0;
  }

  .omnigraph-example :global(.example-tab[aria-selected="true"] .tab-icon) {
    opacity: 1;
  }
</style>
