---
import StaticExampleCodeSection from "./StaticExampleCodeSection.astro";
import StaticExampleOutputSection from "./StaticExampleOutputSection.astro";

interface Props {
  uid: string;
  curlExample: string;
  responseJson: string | null;
  responseSourceLabel: string;
}

const { uid, curlExample, responseJson, responseSourceLabel } = Astro.props;
---

<StaticExampleCodeSection
  badge="cURL"
  headingId={`${uid}-curl-heading`}
  code={curlExample}
  lang="bash"
/>

{
  responseJson ? (
    <StaticExampleOutputSection
      uid={`${uid}-curl`}
      responseJson={responseJson}
      responseSourceLabel={responseSourceLabel}
      heading="Response"
    />
  ) : null
}
