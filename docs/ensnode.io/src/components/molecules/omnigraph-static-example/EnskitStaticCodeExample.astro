---
import type { ENSNamespaceId } from "@ensnode/ensnode-sdk";
import type { SetupPackageManager } from "@lib/examples/omnigraph/build-integration-snippets";

import StaticExampleActionBar from "./StaticExampleActionBar.astro";
import StaticExampleCodeSection from "./StaticExampleCodeSection.astro";
import StaticExampleTabbedSection from "./StaticExampleTabbedSection.astro";
import { buildSdkSetupTabs } from "./build-sdk-setup-tabs";
import { exampleTabClass, staticExampleFooterClass } from "./example-tab-styles";

interface Props {
  exampleId: string;
  uid: string;
  snippet: string;
  setupSnippets: Record<SetupPackageManager, string>;
  responseJson: string | null;
  hostedInstanceDocUrl: string;
  hostedInstanceNamespace: ENSNamespaceId;
}

const {
  exampleId,
  uid,
  snippet,
  setupSnippets,
  responseJson,
  hostedInstanceDocUrl,
  hostedInstanceNamespace,
} = Astro.props;

const { tabs, panels } = buildSdkSetupTabs({
  uid,
  prefix: "enskit",
  setupSnippets,
  responseJson,
});

const docsLinkClass = "underline underline-offset-2 hover:text-[var(--sl-color-text-accent)]";
const outputNote =
  "Output matches the GraphQL Response snapshot; live output depends on your ENSNode instance.";
---

<StaticExampleActionBar
  variant="stackblitz"
  hostedInstanceDocUrl={hostedInstanceDocUrl}
  hostedInstanceNamespace={hostedInstanceNamespace}
  staticExampleId={exampleId}
/>

<StaticExampleCodeSection badge="TSX (React)" code={snippet} lang="tsx" />

<StaticExampleTabbedSection
  tabsRootId={`${uid}-enskit`}
  tablistAriaLabel="Setup and output"
  srHeading={{ id: `${uid}-enskit-setup-heading`, label: "enskit setup and output" }}
  tabs={tabs}
  panels={panels}
  tabButtonClass={exampleTabClass}
  tabIconClass="tab-icon"
/>

<p class={staticExampleFooterClass}>
  {responseJson ? `${outputNote} ` : ""}
  See the{" "}
  <a href="/docs/integrate/integration-options/enskit" class={docsLinkClass}>enskit docs</a>
  {" "}for gql.tada plugin and provider setup.
</p>
