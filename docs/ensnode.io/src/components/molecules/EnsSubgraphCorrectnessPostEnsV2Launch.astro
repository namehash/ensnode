---
import { Aside } from "@astrojs/starlight/components";
const { isEnsV2Launched = false } = Astro.props;
const ensSubgraphCorrectnessMessage = isEnsV2Launched
  ? "ENSv2 has launched, the ENS Subgraph no longer returns correct data."
  : "As soon as ENSv2 launches, the ENS Subgraph will no longer return correct data.";
---

<Aside type="danger" title="ENS Subgraph correctness after ENSv2 launch">
  {ensSubgraphCorrectnessMessage} Transition your apps now to the new ENS Omnigraph API to be ENSv2 ready.
</Aside>
