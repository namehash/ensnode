---
import { Code } from "@astrojs/starlight/components";

interface Props {
  badge: string;
  headingId?: string;
  bordered?: boolean;
  code: string;
  lang: string;
}

const { badge, headingId, bordered = true, code, lang } = Astro.props;

const badgeClass =
  "inline-flex items-center rounded-full bg-[var(--sl-color-gray-5)] px-2.5 py-0.5 text-[0.7rem] font-medium tracking-wide text-[var(--sl-color-gray-2)] dark:bg-[var(--sl-color-gray-6)]";
const sectionClass = bordered
  ? "border-b border-black/[0.05] px-4 pb-5 pt-6 dark:border-white/[0.06] md:px-5"
  : "px-4 pb-5 pt-6 md:px-5";
---

<section class={sectionClass} {...headingId ? { "aria-labelledby": headingId } : {}}>
  <div class="mb-2.5">
    <span id={headingId} class={badgeClass}>
      {badge}
    </span>
  </div>
  <div class="min-w-0 [&_.expressive-code]:rounded-lg">
    <Code code={code} lang={lang} />
  </div>
</section>
