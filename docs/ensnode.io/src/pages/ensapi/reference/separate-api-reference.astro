---
import ENSNode2DLight from "../../../assets/light-logo.svg";
import HeaderButtons from "../../../components/molecules/HeaderButtons";
import Layout from "../../../layouts/Layout.astro";
import openapiSpec from "@workspace/docs/docs.ensnode.io/ensapi-openapi.json";

const scalarConfig = JSON.stringify({
  content: openapiSpec,
  theme: "none",
  agent: { disabled: true },
  hideDownloadButton: true,
  hiddenClients: true,
  telemetry: false,
  defaultOpenAllTags: true,
  expandAllResponses: true,
  hideClientButton: true,
  hideSearch: true,
  showOperationId: true,
  showSidebar: true,
  showDeveloperTools: "never",
  isEditable: false,
  isLoading: false,
  documentDownloadType: "both",
  hideTestRequestButton: false,
  hideDarkModeToggle: false,
  withDefaultFonts: true,
  expandAllModelSections: true,
  customCss: `.scalar-mcp-layer { display: none !important; }`,
});
---

<style>


  /* custom --scalar-custom-header-height to match header height */
  :root {
    --scalar-custom-header-height: 56px;
  }
  @media (min-width: 640px) {
    :root {
      --scalar-custom-header-height: 70px;
    }
  }
</style>


<Layout title="ENSApi API Reference">

  <header class="fixed top-0 w-full z-20 h-[56px] py-[9px] sm:h-[70px] sm:py-4 select-none border border-b border-gray-200 bg-white">
    <div class="box-border w-full max-w-7xl mx-auto items-center justify-between flex flex-row pl-5 pr-3 sm:px-8">
        <div class="flex flex-row lg:gap-2 xl:gap-7 justify-between items-center">
            <div class="flex flex-row justify-between items-center gap-2 sm:gap-[14px] cursor-pointer flex-shrink-0 sm:mr-10 lg::mr-[76px]">
                <a
                    href="/"
                    class="flex justify-center items-center text-black not-italic font-bold text-[21.539px] leading-[26.51px] tracking-[-0.907px] sm:text-[26px] sm:leading-8 sm:tracking-[-1.113px]"
                >
                    <img src={ENSNode2DLight.src} class="h-8 min-[800px]:h-10" alt="ENSNode" />
                </a>
            </div>
        </div>

        <HeaderButtons client:load isScrollable={false}/>
    </div>
  </header>

    <!-- spacer to physically take up the space behind the header -->
  <div class="h-[56px] sm:h-[70px]"></div>

    <!-- scalar -->
  <div id="scalar-api-reference" data-config={scalarConfig}></div>

  <script>
    import "@scalar/api-reference/style.css";
    import { createApiReference } from "@scalar/api-reference";

    const el = document.getElementById("scalar-api-reference")!;
    const config = JSON.parse(el.dataset.config!);
    createApiReference(el, config);
  </script>

</Layout>
