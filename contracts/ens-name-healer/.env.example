# Export all variables so `source .env` makes them visible to forge subprocesses.

# Address that becomes owner of the proxy (required).
export OWNER_ADDRESS=

# Address to assign as publisher at deploy time (optional).
# Also used by script/SetPublisher.s.sol to update an existing proxy.
# Use the zero address to start paused or to pause publishing later.
export PUBLISHER_ADDRESS=

# Deployed ENSNameHealer proxy address (required for SetPublisher script).
export PROXY_ADDRESS=

# Private key of the deployer account (required for deployment).
# Must hold enough ETH to cover gas on the target network.
export DEPLOYER_PRIVATE_KEY=

# RPC URLs for each network.
export SEPOLIA_RPC_URL=
export MAINNET_RPC_URL=

# Etherscan key for source verification.
export ETHERSCAN_API_KEY=

# CREATE2 vanity deploy (script/DeployCreate2.s.sol). Optional; standard deploy uses Deploy.s.sol.
# Hex prefix without 0x (e.g. 1abe15 → 0x1abe15...). Adjust during review as needed.
export CREATE2_PREFIX=1abe15
# Mine with script/mine-create2-salt.sh, then set:
export CREATE2_SALT=
# Optional; defaults to zero (impl address is embedded in proxy init code).
export CREATE2_IMPL_SALT=
